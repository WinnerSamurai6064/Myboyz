# ── Telegram ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=

# ── NVIDIA NIM (free tier, 40 RPM, no credit card) ─
NVIDIA_NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model IDs – Kimi K2.5 for ranking/summaries, GLM for commands/drafts
NIM_MODEL_KIMI=moonshotai/kimi-k2.5
NIM_MODEL_GLM=z-ai/glm4.7

# ── Azure ─────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
BLOB_CONTAINER_NAME=nemoclaw-state
SESSION_BLOB_NAME=insta-session.pkl

# ── Runtime ───────────────────────────────────────
ACTIVE_WINDOW_SECONDS=300
TRIGGER_SECRET=supersecretkey
